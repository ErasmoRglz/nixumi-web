# Supabase Configuration
# Get these values from your Supabase project: Project Settings → API
PUBLIC_SUPABASE_URL=https://nixumibd.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Calendar (optional - for appointment booking)
# Get your Calendar Schedule ID from Google Calendar → Appointment Schedule
CALENDAR_SCHEDULE_ID=your-schedule-id-here
