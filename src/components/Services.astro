---
const services = [
  {
    title: 'Chatbots de Ventas con IA',
    description:
      'Atienden, cotizan y cierran ventas en WhatsApp las 24 horas. Integrados con tu base de datos para mostrar inventario real en tiempo real.',
    iconBg: 'rgba(139,92,246,0.10)',
    iconStroke: 'var(--color-purple)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />`,
  },
  {
    title: 'Captación y Calificación de Leads',
    description:
      'Cada prospecto se califica automáticamente según tu criterio. Los leads calientes llegan a tu equipo listos para cerrar, sin que pierdas tiempo en los fríos.',
    iconBg: 'rgba(95,184,95,0.10)',
    iconStroke: 'var(--color-green)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />`,
  },
  {
    title: 'Integraciones a la Medida',
    description:
      'Conectamos tu WhatsApp con tu CRM, calendario, base de datos o sistema interno. Si tiene API, lo conectamos. Sin límites ni intermediarios.',
    iconBg: 'rgba(201,168,212,0.18)',
    iconStroke: 'var(--color-lavender)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />`,
  },
  {
    title: 'Agentes Especializados',
    description:
      'Bots para inmobiliarias, clínicas, restaurantes, tiendas y más. Cada uno entrenado con tu tono, tu oferta y el conocimiento real de tu negocio.',
    iconBg: 'rgba(139,92,246,0.10)',
    iconStroke: 'var(--color-purple)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />`,
  },
  {
    title: 'Human Takeover',
    description:
      'El bot atiende, pero tu equipo puede tomar control en cualquier momento con un solo comando. La IA y tus agentes humanos trabajando en equipo.',
    iconBg: 'rgba(95,184,95,0.10)',
    iconStroke: 'var(--color-green)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />`,
  },
  {
    title: 'Soporte y Evolución',
    description:
      'No es un producto que compras y olvidas. Le damos mantenimiento continuo y lo mejoramos con los datos reales de tus clientes mes a mes.',
    iconBg: 'rgba(201,168,212,0.18)',
    iconStroke: 'var(--color-lavender)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />`,
  },
] as const;
---

<section id="servicios" class="aurora-medium py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- Heading -->
    <div class="text-center mb-14 fade-in">
      <div
        class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full mb-4"
        style="background:rgba(95,184,95,0.10); color:var(--color-green)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        Nuestros servicios
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4" style="color:var(--color-navy)">
        Automatización a la medida de tu negocio
      </h2>
      <p class="text-base md:text-lg max-w-xl mx-auto text-slate-500 dark:text-slate-400">
        Desde el primer mensaje hasta el cierre de venta, cubrimos todo
        el proceso de atención con inteligencia artificial.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((s, i) => (
        <article
          class={`service-card fade-in fade-d${(i % 3) + 1} group relative rounded-2xl p-7 cursor-default
                  transition-all duration-300`}
          style="background:var(--color-smoke); border:1.5px solid rgba(168,181,196,0.25)"
        >
          <!-- Icon -->
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110"
            style={`background:${s.iconBg}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke={s.iconStroke}
              aria-hidden="true"
              set:html={s.icon}
            />
          </div>

          <h3 class="text-lg font-bold mb-2 transition-colors duration-200 group-hover:text-purple-600" style="color:var(--color-navy)">
            {s.title}
          </h3>
          <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
            {s.description}
          </p>

          <!-- Hover: purple bottom border accent -->
          <div
            class="absolute bottom-0 left-6 right-6 h-0.5 rounded-full scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"
            style="background:var(--color-purple)"
            aria-hidden="true"
          ></div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .service-card:hover {
    background: #fff !important;
    border-color: rgba(139, 92, 246, 0.35) !important;
    box-shadow: 0 8px 32px rgba(139, 92, 246, 0.10), 0 2px 8px rgba(37, 53, 69, 0.06);
    transform: translateY(-4px);
  }
  :global(.dark) .service-card:hover {
    background: #1e293b !important;
    border-color: rgba(139, 92, 246, 0.45) !important;
    box-shadow: 0 8px 32px rgba(139, 92, 246, 0.18), 0 2px 8px rgba(0, 0, 0, 0.20);
  }
</style>
