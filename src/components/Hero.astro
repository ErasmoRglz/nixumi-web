---
const WA = 'https://wa.me/5212381238389?text=Hola%2C%20quiero%20automatizar%20mi%20negocio';
---

<section class="aurora-showcase relative min-h-screen flex items-center pt-28 pb-16">

  <div class="max-w-7xl mx-auto px-4 md:px-6 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- ── Left: Copy ── -->
      <div class="fade-in">

        <!-- Eyebrow badge -->
        <div
          class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full mb-6"
          style="background:rgba(139,92,246,0.1); color:var(--color-purple)"
        >
          <span
            class="w-2 h-2 rounded-full animate-pulse"
            style="background:var(--color-purple)"
          ></span>
          Automatización con IA para WhatsApp
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6" style="color:var(--color-navy)">
          Tu negocio atendiendo clientes
          <span style="color:var(--color-purple)"> 24/7</span> por
          <span style="color:var(--color-green)"> WhatsApp</span>
        </h1>

        <p class="text-lg md:text-xl leading-relaxed mb-8 max-w-lg text-slate-600 dark:text-slate-300">
          Construimos chatbots inteligentes con IA que responden, califican leads
          y cierran ventas mientras tú te concentras en crecer tu negocio.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          <a
            href={WA}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-nx btn-primary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Hablar con Nixumi
          </a>

          <a
            href="#casos"
            class="btn-nx btn-outline"
          >
            Ver casos de éxito
            <svg xmlns="http://www.w3.org/2000/svg" class="btn-arrow-down h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
            </svg>
          </a>
        </div>

        <!-- Trust signals -->
        <ul class="flex flex-wrap gap-4" role="list">
          {['Activo en 7 días', 'Sin código', 'Hecho a medida'].map(t => (
            <li class="flex items-center gap-1.5 text-sm font-medium text-slate-500 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true" style="color:var(--color-green)">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              {t}
            </li>
          ))}
        </ul>
      </div>

      <!-- ── Right: WhatsApp phone mockup ── -->
      <div class="hidden lg:flex justify-center items-center fade-in fade-d2">
        <div class="relative">

          <!-- Glow -->
          <div
            class="absolute -inset-6 rounded-[3rem] blur-3xl pointer-events-none"
            style="background:linear-gradient(135deg,rgba(139,92,246,0.25),rgba(95,184,95,0.2))"
            aria-hidden="true"
          ></div>

          <!-- Phone shell -->
          <div class="relative rounded-[2.5rem] p-[10px] shadow-2xl w-72" style="background:#1a1a2e">

            <!-- Status bar -->
            <div class="flex items-center justify-between px-5 py-1.5 text-white text-[10px]">
              <span>9:41</span>
              <div class="w-20 h-[5px] rounded-full" style="background:rgba(255,255,255,0.15)"></div>
              <div class="flex gap-1">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="white"><path d="M1.5 8.5A13 13 0 0 1 12 4a13 13 0 0 1 10.5 4.5"/><path d="M5 12a9.5 9.5 0 0 1 14 0"/><path d="M8.5 15.5A6 6 0 0 1 12 14a6 6 0 0 1 3.5 1.5"/><circle cx="12" cy="19" r="1" fill="white"/></svg>
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="white"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M22 11v2"/></svg>
              </div>
            </div>

            <!-- Screen -->
            <div class="rounded-[2rem] overflow-hidden bg-[#ECE5DD] dark:bg-[#0B141A]">

              <!-- WA Header -->
              <div class="px-3 py-2.5 flex items-center gap-2.5" style="background:#075E54">
                <div class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-white text-sm flex-shrink-0" style="background:var(--color-green)">G</div>
                <div class="flex-1 min-w-0">
                  <p class="text-white text-sm font-semibold truncate">Graciela — Nixumi IA</p>
                  <p class="text-[10px]" style="color:rgba(255,255,255,0.65)">en línea ahora</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="rgba(255,255,255,0.7)" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75Z" />
                </svg>
              </div>

              <!-- Chat messages -->
              <div class="px-2.5 py-3 space-y-2" style="min-height:340px">

                <!-- Incoming -->
                <div class="flex">
                  <div class="rounded-t-2xl rounded-br-2xl rounded-bl-sm px-3 py-2 max-w-[82%] shadow-sm bg-white dark:bg-[#1F2C34]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px] leading-relaxed">Hola! ¿Tienen lotes disponibles?</p>
                    <p class="text-[9px] text-right mt-0.5 text-[#aaa] dark:text-[#8696A0]">10:32</p>
                  </div>
                </div>

                <!-- Outgoing -->
                <div class="flex justify-end">
                  <div class="rounded-t-2xl rounded-bl-2xl rounded-br-sm px-3 py-2 max-w-[82%] shadow-sm bg-[#DCF8C6] dark:bg-[#005C4B]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px] leading-relaxed">¡Hola! Soy Graciela, asesora de El Valle Bagoj. ¡Claro que sí! Tenemos varias opciones disponibles.</p>
                    <p class="text-[9px] text-right mt-0.5 flex items-center justify-end gap-1 text-[#999] dark:text-[#8696A0]">10:32
                      <svg class="w-3 h-3" viewBox="0 0 16 11" fill="#53bdeb"><path d="M11.071.653a.75.75 0 00-1.142-.96L5.96 5.453l-1.89-1.89a.75.75 0 10-1.061 1.06l2.5 2.5a.75.75 0 001.1-.049l4.462-5.421z"/><path d="M14.071.653a.75.75 0 00-1.142-.96L8.96 5.453l-.39-.39a.75.75 0 00-1.061 1.06l1 1a.75.75 0 001.1-.049l4.462-5.421z"/></svg>
                    </p>
                  </div>
                </div>

                <!-- Incoming -->
                <div class="flex">
                  <div class="rounded-t-2xl rounded-br-2xl rounded-bl-sm px-3 py-2 max-w-[78%] shadow-sm bg-white dark:bg-[#1F2C34]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px]">¿Cuánto cuestan?</p>
                    <p class="text-[9px] text-right mt-0.5 text-[#aaa] dark:text-[#8696A0]">10:33</p>
                  </div>
                </div>

                <!-- Outgoing -->
                <div class="flex justify-end">
                  <div class="rounded-t-2xl rounded-bl-2xl rounded-br-sm px-3 py-2 max-w-[82%] shadow-sm bg-[#DCF8C6] dark:bg-[#005C4B]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px] leading-relaxed">Desde $299,000 MXN con plan de financiamiento. Lotes desde 200 m².</p>
                    <p class="text-[9px] text-right mt-0.5 text-[#999] dark:text-[#8696A0]">10:33</p>
                  </div>
                </div>

                <!-- Incoming -->
                <div class="flex">
                  <div class="rounded-t-2xl rounded-br-2xl rounded-bl-sm px-3 py-2 max-w-[82%] shadow-sm bg-white dark:bg-[#1F2C34]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px]">¿Puedo agendar una visita?</p>
                    <p class="text-[9px] text-right mt-0.5 text-[#aaa] dark:text-[#8696A0]">10:34</p>
                  </div>
                </div>

                <!-- Outgoing -->
                <div class="flex justify-end">
                  <div class="rounded-t-2xl rounded-bl-2xl rounded-br-sm px-3 py-2 max-w-[82%] shadow-sm bg-[#DCF8C6] dark:bg-[#005C4B]">
                    <p class="text-gray-800 dark:text-[#E9EDEF] text-[11px] leading-relaxed">¡Por supuesto! ¿Cuándo te queda mejor? Tenemos horarios este fin de semana.</p>
                    <p class="text-[9px] text-right mt-0.5 text-[#999] dark:text-[#8696A0]">10:34</p>
                  </div>
                </div>

                <!-- Typing indicator -->
                <div class="flex">
                  <div class="rounded-2xl px-4 py-2.5 shadow-sm bg-white dark:bg-[#1F2C34]">
                    <div class="flex gap-1 items-center h-3">
                      <span class="w-1.5 h-1.5 rounded-full animate-bounce bg-[#999] dark:bg-[#8696A0]" style="animation-delay:0ms"></span>
                      <span class="w-1.5 h-1.5 rounded-full animate-bounce bg-[#999] dark:bg-[#8696A0]" style="animation-delay:150ms"></span>
                      <span class="w-1.5 h-1.5 rounded-full animate-bounce bg-[#999] dark:bg-[#8696A0]" style="animation-delay:300ms"></span>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- Badge: IA activa -->
          <div class="absolute -bottom-3 -right-3 bg-white dark:bg-slate-800 rounded-2xl px-3 py-2 shadow-xl" style="border:1px solid rgba(168,181,196,0.3)">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full animate-pulse" style="background:var(--color-green)"></span>
              <span class="text-xs font-semibold" style="color:var(--color-navy)">IA respondiendo</span>
            </div>
          </div>

          <!-- Badge: 24/7 -->
          <div class="absolute -top-3 -left-3 rounded-2xl px-3 py-2 shadow-xl" style="background:var(--color-purple)">
            <span class="text-xs font-bold text-white">24/7 activo</span>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
