---
const sinNixumi = [
  'Pierdes ventas fuera de horario de oficina',
  'Tu equipo repite las mismas respuestas 100 veces al día',
  'Los prospectos se enfrían antes de que los contestes',
];

const conNixumi = [
  'Atención instantánea 24/7, incluso en madrugada',
  'Tu IA responde, cotiza y agenda sin intervención humana',
  'Capturamos y calificamos leads automáticamente',
];
---

<section class="aurora-medium py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- Heading -->
    <div class="text-center mb-14 fade-in">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4" style="color:var(--color-navy)">
        ¿Estás perdiendo ventas mientras duermes?
      </h2>
      <p class="text-base md:text-lg max-w-xl mx-auto text-slate-500 dark:text-slate-400">
        Cada hora sin respuesta es un prospecto que le compra a tu competencia.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-10 max-w-4xl mx-auto">

      <!-- Sin Nixumi -->
      <div
        class="fade-in fade-d1 rounded-2xl p-8 bg-[#F0F2F4] dark:bg-slate-800"
        style="border:1.5px solid #E2E6EA"
      >
        <!-- Icon -->
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 bg-red-100 dark:bg-red-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="#EF4444" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </div>
          <h3 class="text-xl font-bold" style="color:var(--color-navy)">Sin Nixumi</h3>
        </div>

        <ul class="space-y-4" role="list">
          {sinNixumi.map(item => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="#EF4444" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
              <span class="text-base leading-snug text-slate-600 dark:text-slate-300">{item}</span>
            </li>
          ))}
        </ul>

        <!-- Ilustración sutil -->
        <div class="mt-8 rounded-xl p-4 flex items-center gap-3 bg-red-50 dark:bg-red-900/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#EF4444" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <p class="text-sm font-medium" style="color:#EF4444">
            El 78% de los leads compra al primero que responde
          </p>
        </div>
      </div>

      <!-- Con Nixumi -->
      <div
        class="fade-in fade-d2 rounded-2xl p-8 relative overflow-hidden bg-white dark:bg-[#1a2535]"
        style="border:2px solid var(--color-purple); box-shadow:0 0 0 1px rgba(139,92,246,0.08), 0 8px 32px rgba(139,92,246,0.10)"
      >
        <!-- Highlight ribbon -->
        <div
          class="absolute top-0 right-0 text-white text-[10px] font-bold px-3 py-1 rounded-bl-xl"
          style="background:var(--color-purple)"
        >
          SOLUCIÓN
        </div>

        <!-- Icon -->
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(95,184,95,0.12)">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="var(--color-green)" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold" style="color:var(--color-navy)">Con Nixumi</h3>
        </div>

        <ul class="space-y-4" role="list">
          {conNixumi.map(item => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="var(--color-green)" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base leading-snug font-medium" style="color:var(--color-navy)">{item}</span>
            </li>
          ))}
        </ul>

        <!-- Stat -->
        <div class="mt-8 rounded-xl p-4 flex items-center gap-3" style="background:rgba(95,184,95,0.07)">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="var(--color-green)" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
          <p class="text-sm font-semibold" style="color:var(--color-green)">
            Respuesta automática en menos de 3 segundos, todo el día
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
