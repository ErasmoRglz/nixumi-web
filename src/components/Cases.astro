---
const WA_CASO = 'https://wa.me/5212381238389?text=Hola%2C%20quiero%20ser%20el%20pr%C3%B3ximo%20caso%20de%20%C3%A9xito%20de%20Nixumi';

const metrics = [
  { value: '24/7',  label: 'Atención automatizada'          },
  { value: '100%',  label: 'Precios sincronizados con BD'   },
  { value: '0',     label: 'Leads perdidos fuera de horario'},
];

const stack = [
  'WhatsApp Business',
  'Supabase',
  'n8n',
  'Gemini 2.5 Pro',
  'YCloud',
];
---

<section id="casos" class="aurora-medium py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- Heading -->
    <div class="text-center mb-14 fade-in">
      <div
        class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full mb-4"
        style="background:rgba(95,184,95,0.10); color:var(--color-green)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
        </svg>
        Casos de éxito
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4" style="color:var(--color-navy)">
        Resultados reales de nuestros clientes
      </h2>
      <p class="text-base md:text-lg max-w-xl mx-auto text-slate-500 dark:text-slate-400">
        No son demos ni prototipos. Son bots en producción atendiendo
        clientes en este momento.
      </p>
    </div>

    <!-- ── Featured case card ── -->
    <div class="max-w-3xl mx-auto fade-in">
      <div
        class="rounded-3xl p-8 md:p-12 bg-white dark:bg-[#1a2535]"
        style="border:1.5px solid rgba(168,181,196,0.3); box-shadow:0 4px 24px rgba(37,53,69,0.07)"
      >

        <!-- a) Card header row -->
        <div class="flex items-start justify-between gap-4 mb-6">
          <div
            class="inline-flex items-center gap-2 text-xs font-bold px-3 py-1.5 rounded-full"
            style="background:rgba(95,184,95,0.12); color:var(--color-green); border:1px solid rgba(95,184,95,0.3)"
          >
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background:var(--color-green)"></span>
            Caso en producción
          </div>
          <span
            class="text-xs font-semibold px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-300"
          >
            Bienes raíces
          </span>
        </div>

        <!-- b) Client name -->
        <h3 class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-2" style="color:var(--color-navy)">
          Inmobiliaria El Valle Bagoj
        </h3>

        <!-- c) Location -->
        <p class="text-sm mb-7" style="color:var(--color-slate)">
          📍 Altepexi, Puebla · México
        </p>

        <!-- d) Divider -->
        <div class="border-t mb-8" style="border-color:rgba(168,181,196,0.25)"></div>

        <!-- e) Metrics -->
        <div class="grid grid-cols-3 gap-6 mb-8">
          {metrics.map((m, i) => (
            <div class={`text-center fade-in fade-d${i + 1}`}>
              <p
                class="text-5xl font-extrabold tracking-tight leading-none"
                style="color:var(--color-purple)"
              >
                {m.value}
              </p>
              <p class="text-xs font-medium mt-2 leading-snug" style="color:var(--color-slate)">
                {m.label}
              </p>
            </div>
          ))}
        </div>

        <!-- f) Divider -->
        <div class="border-t mb-8" style="border-color:rgba(168,181,196,0.25)"></div>

        <!-- g) Description -->
        <p class="text-base leading-relaxed max-w-prose mb-8 text-slate-600 dark:text-slate-300">
          Automatizamos la atención al cliente de una inmobiliaria con múltiples
          lotificaciones activas. <strong style="color:var(--color-navy)">"Graciela"</strong>
          —la asesora virtual de IA— atiende, cotiza lotes con precios reales
          desde base de datos y agenda visitas sin intervención humana, incluso
          en madrugada y fines de semana.
        </p>

        <!-- h) Tech stack chips -->
        <div class="flex flex-wrap gap-2">
          {stack.map(t => (
            <span
              class="text-sm font-medium px-3 py-1 rounded-full"
              style="background:var(--color-smoke); border:1px solid rgba(168,181,196,0.45); color:var(--color-navy)"
            >
              {t}
            </span>
          ))}
        </div>

      </div>

      <!-- ── Below card: next case CTA ── -->
      <div class="text-center mt-8 fade-in">
        <a
          href={WA_CASO}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-nx btn-primary btn-sm"
        >
          Hablar con Nixumi
          <svg xmlns="http://www.w3.org/2000/svg" class="btn-arrow h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>
