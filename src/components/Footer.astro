---
const navLinks = [
  { href: '#servicios', label: 'Servicios'      },
  { href: '#proceso',   label: 'Proceso'        },
  { href: '#casos',     label: 'Casos de éxito' },
  { href: '#precios',   label: 'Precios'        },
  { href: '#faq',       label: 'FAQ'            },
];

---

<footer style="background:#1a2535">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-20">

    <!-- ── Grid superior ── -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- COL 1 — Marca (col-span-2 en desktop) -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a href="/" class="inline-block mb-4">
          <img
            src="/nixumi-logo-white-text.webp"
            alt="Nixumi - Automatización de WhatsApp con IA"
            width="160"
            height="64"
            class="h-24 w-auto object-contain"
          />
        </a>

        <p class="text-base font-semibold mb-3 text-white">
          Automatización inteligente para negocios reales.
        </p>

        <p class="text-sm leading-relaxed mb-5" style="color:rgba(168,181,196,0.8)">
          Construimos chatbots con IA que trabajan 24/7 por tu negocio.
          Hecho a medida, sin código, sin complicaciones.
        </p>

        <span
          class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full"
          style="background:rgba(255,255,255,0.06); color:rgba(168,181,196,0.9); border:1px solid rgba(168,181,196,0.15)"
        >
        Hecho en Puebla, México
        </span>
      </div>

      <!-- COL 2 — Navegación -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-5 uppercase tracking-wider">
          Explorar
        </h3>
        <ul class="space-y-3" role="list">
          {navLinks.map(l => (
            <li>
              <a
                href={l.href}
                class="text-sm transition-colors duration-200"
                style="color:rgba(168,181,196,0.75)"
                onmouseover="this.style.color='var(--color-green)'"
                onmouseout="this.style.color='rgba(168,181,196,0.75)'"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- COL 3 — Contacto -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-5 uppercase tracking-wider">
          Hablemos
        </h3>
        <ul class="space-y-4" role="list">

          <!-- WhatsApp -->
          <li>
            <a
              href="https://wa.me/5212381238389?text=Hola"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Chatear con Nixumi por WhatsApp"
              class="flex items-start gap-2.5 text-sm group transition-colors duration-200"
              style="color:rgba(168,181,196,0.75)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5 transition-colors duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" style="color:var(--color-green)">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
              </svg>
              <span>
                <span class="block font-medium" style="color:rgba(255,255,255,0.7)">WhatsApp</span>
                +52 238 123 8389
              </span>
            </a>
          </li>

          

          <!-- Hours -->
          <li class="flex items-start gap-2.5 text-sm" style="color:rgba(168,181,196,0.65)">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" style="color:var(--color-slate)">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span>
              <span class="block font-medium" style="color:rgba(255,255,255,0.7)">Nuestros Horarios</span>
              Lun – Vie 8am – 7pm (CST)
            </span>
          </li>

        </ul>
      </div>



        </div><!-- /grid -->

    <!-- ── Separador ── -->
    <div class="my-10 border-t" style="border-color:rgba(168,181,196,0.12)"></div>

    <!-- ── Fila inferior ── -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 w-full">
      <p class="text-sm flex flex-wrap items-center gap-x-2 gap-y-1" style="color:rgba(168,181,196,0.5)">
        <span>© 2026 Nixumi</span>
        <span aria-hidden="true">·</span>
        <a
          href="/aviso-de-privacidad"
          class="transition-colors duration-200"
          onmouseover="this.style.color='var(--color-green)'"
          onmouseout="this.style.color='rgba(168,181,196,0.5)'"
        >
          Aviso de Privacidad
        </a>
        <span aria-hidden="true">·</span>
        <a
          href="/terminos-y-condiciones"
          class="transition-colors duration-200"
          onmouseover="this.style.color='var(--color-green)'"
          onmouseout="this.style.color='rgba(168,181,196,0.5)'"
        >
          Términos y Condiciones
        </a>
      </p>
      <p class="text-sm" style="color:rgba(168,181,196,0.5)">
        Construido con <span style="color:var(--color-green)">♥</span> en Puebla, México.
      </p>
    </div>

  </div>
</footer>
