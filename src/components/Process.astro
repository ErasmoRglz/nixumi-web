---
const steps = [
  {
    num: '01',
    title: 'Diagnóstico',
    badge: '30 min · Gratis',
    desc: 'Analizamos tu negocio, tu canal de ventas y dónde se te escapan oportunidades. Sin costo, sin compromiso.',
  },
  {
    num: '02',
    title: 'Propuesta a medida',
    badge: 'Precio fijo',
    desc: 'Te entregamos un plan con alcance, tiempos y precio fijo. Nada de cotizaciones vagas ni sorpresas en la factura.',
  },
  {
    num: '03',
    title: 'Construcción',
    badge: '5 a 15 días',
    desc: 'Desarrollamos tu chatbot, lo conectamos con tus sistemas y lo entrenamos con tu información real. Avances cada 2–3 días.',
  },
  {
    num: '04',
    title: 'Lanzamiento y mejora continua',
    badge: 'Mes a mes',
    desc: 'Activamos el bot, capacitamos a tu equipo y lo ajustamos con los datos reales de tus primeros clientes atendidos.',
  },
] as const;
---

<section id="proceso" class="aurora-medium py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 md:px-6">

    <!-- Heading -->
    <div class="text-center mb-16 fade-in">
      <div
        class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full mb-4"
        style="background:rgba(139,92,246,0.10); color:var(--color-purple)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
        Cómo trabajamos
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4" style="color:var(--color-navy)">
        Del diagnóstico al lanzamiento en menos de 15 días
      </h2>
      <p class="text-base md:text-lg max-w-xl mx-auto text-slate-500 dark:text-slate-400">
        Proceso claro, precio fijo, sin sorpresas. Así trabajamos con cada cliente.
      </p>
    </div>

    <!-- Steps grid + connector line -->
    <div class="relative">

      <!--
        Dashed connector line (desktop only).
        Sits at the vertical midpoint of the text-6xl numbers (~2.25rem from top).
        z-0 so the number backgrounds (bg-white) occlude it.
      -->
      <div
        class="hidden lg:block absolute pointer-events-none"
        style="
          top: 2.25rem;
          left: calc(100% / 8);
          right: calc(100% / 8);
          height: 0;
          border-top: 1.5px dashed rgba(168,181,196,0.55);
          z-index: 0;
        "
        aria-hidden="true"
      ></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 relative">
        {steps.map((step, i) => (
          <div class={`fade-in fade-d${i + 1} relative`} style="z-index:1">

            <!-- Number: inline bg-white block cuts the dashed line visually -->
            <div class="mb-5">
              <span
                class="inline-block text-6xl font-bold tracking-tight leading-none bg-white dark:bg-[#1a2535] pr-3"
                style="color:var(--color-purple)"
              >
                {step.num}
              </span>
            </div>

            <!-- Badge -->
            <span
              class="inline-block text-[11px] font-semibold px-2.5 py-0.5 rounded-full mb-3"
              style="background:rgba(139,92,246,0.08); color:var(--color-purple)"
            >
              {step.badge}
            </span>

            <!-- Title -->
            <h3 class="text-lg font-bold mb-2 leading-snug" style="color:var(--color-navy)">
              {step.title}
            </h3>

            <!-- Description -->
            <p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
              {step.desc}
            </p>

            <!-- Step-to-step arrow (visible only on sm grid, between pairs) -->
            {i % 2 === 0 && i < 3 && (
              <div
                class="hidden sm:flex lg:hidden absolute top-8 -right-5 items-center"
                aria-hidden="true"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="rgba(168,181,196,0.8)">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </div>
            )}

          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA strip -->
    <div class="mt-16 fade-in">
      <div
        class="max-w-3xl mx-auto rounded-2xl px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4"
        style="background:rgba(139,92,246,0.05); border:1.5px solid rgba(139,92,246,0.15)"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0"
            style="background:rgba(139,92,246,0.10)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="var(--color-purple)" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-600 dark:text-slate-300">
            El paso 1 no te cuesta nada.
            <span class="block text-xs mt-0.5" style="color:var(--color-slate)">30 minutos para saber si Nixumi es para ti.</span>
          </p>
        </div>
        <a
          href="https://wa.me/5212381238389?text=Hola%2C%20quiero%20agendar%20mi%20diagn%C3%B3stico%20gratuito"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-nx btn-secondary btn-sm"
        >
          Agendar diagnóstico gratis
          <svg xmlns="http://www.w3.org/2000/svg" class="btn-arrow h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>
